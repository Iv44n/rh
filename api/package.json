{
  "name": "app",
  "version": "1.0.50",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "compile": "bun build --compile --minify-whitespace --minify-syntax --target bun src/index.ts --outfile server",
    "test": "bun test",
    "lint": "biome check",
    "lint:fix": "biome check --fix",
    "format": "biome format --write"
  },
  "dependencies": {
    "elysia": "latest"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "bun-types": "latest"
  },
  "module": "src/index.js"
}
